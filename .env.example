# --- Auth (optional, leave empty to disable) ---
VITE_BASIC_AUTH_USER=                    # username shown on the login screen
VITE_BASIC_AUTH_PASS=                    # password shown on the login screen

# --- LLM keys ---
LLM_MODEL=anthropic/claude-opus-4-6
LLM_API_KEY=
OPENAI_API_KEY=                          # embeddings + RAG script

# --- Backend connection (leave empty for local dev) ---
VITE_API_BASE_URL=                       # GCP backend URL (e.g. https://your-api.run.app); leave blank for local dev proxy
VITE_BACKEND_API_KEY=                    # x-api-key sent by frontend — must match BACKEND_API_KEY on the server
BACKEND_API_KEY=                         # server-side key the backend checks (leave empty to disable)
