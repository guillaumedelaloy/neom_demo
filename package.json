{
  "name": "neom-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || ^24.0.0 || ^25.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:free-8001": "bash scripts/free-port.sh 8001",
    "dev:api": "uv run uvicorn api.index:app --reload --reload-dir api --host 127.0.0.1 --port 8001",
    "dev:web:after-api": "wait-on -t 300000 http-get://127.0.0.1:8001/api/health && vite",
    "dev:stack": "pnpm run dev:free-8001 && concurrently -k -n api,web -c blue,green \"pnpm run dev:api\" \"pnpm run dev:web:after-api\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fdir": "^6.5.0",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.16",
    "wait-on": "^8.0.5",
    "rolldown": "1.0.0-rc.15"
  }
}
